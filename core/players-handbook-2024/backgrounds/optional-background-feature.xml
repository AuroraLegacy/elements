<?xml version="1.0" encoding="utf-8" ?>
<elements>
	<info>
		<name>Optional Background Feature</name>
		<author url="https://dndstore.wizards.com/us/en/product/1001494/2024-player-s-handbook-digital-plus-physical-bundle">Wizards of the Coast</author>
		<update version="0.0.1">
			<file name="optional-background-feature.xml" url="https://raw.githubusercontent.com/AuroraLegacy/elements/master/core/players-handbook-2024/backgrounds/optional-background-feature.xml" />
		</update>
	</info>

	<element name="Origin Feat" type="Background Feature" source="Player’s Handbook (2024)" id="ID_WOTC_PHB24_BACKGROUND_FEATURE_ORIGIN_FEAT">
		<supports>Optional Background Feature</supports>
		<description>
			<p>This feature allows you to replace your Background Feature with an Origin Feat of your choice.</p>
			<p><b>Note.</b> If your DM allows you to gain an Origin Feat on top of your Background Feature, instead of using this Optional Background Feature you should take the chosen Feat from the Additional Feat category of the Equipment menu.</p>
		</description>
		<rules>
			<grant type="Grants" id="ID_INTERNAL_GRANT_OPTIONAL_BACKGROUND_FEATURE" />

			<select type="Feat" name="Origin Feat" supports="Origin" />
		</rules>
	</element>

</elements>
