	<!-- Barding was never properly implemented, and is currently not planned, as it don't affect the character in any way. Still maybe at some point in the future it would make sense to adapt normal armor into barding at least for an ease of tracking it for users -->
	<element name="Barding" type="Item" source="Player’s Handbook (2024)" id="ID_WOTC_PHB24_ITEM_BARDING">
		<description>
			<p>Barding is armor designed for a mount. Any type of armor on the Armor table in this chapter can be purchased as barding. The cost is four times the normal cost, and it weighs twice as much.</p>
		</description>
		<setters>
			<set name="category">Mounts &amp; Vehicles</set>
			<set name="cost" currency="gp">0</set>
			<set name="weight" lb="0">—</set>
		</setters>
	</element>

