<?xml version="1.0" encoding="utf-8" ?>
<elements>
	<info>
		<name>Wondrous Items</name>
		<description>Wondrous Items from Eberron: Forge of the Artificer.</description>
		<author url="https://marketplace.dndbeyond.com/category/5147000?pid=D5147000">Wizards of the Coast</author>
		<update version="0.0.1">
			<file name="items-wondrous.xml" url="https://raw.githubusercontent.com/AuroraLegacy/elements/master/supplements/eberron-forge-of-the-artificer/items/items-wondrous.xml" />
		</update>
	</info>

	<element name="Boots of the Winding Path" type="Magic Item" source="Eberron: Forge of the Artificer" id="ID_WOTC_EFOTA_MAGIC_ITEM_BOOTS_OF_THE_WINDING_PATH">
		<description>
			<p>While wearing these boots, you can take a Bonus Action to teleport up to 15 feet to an unoccupied space you can see. You must have occupied that space at some point during the current turn.</p>
		</description>
		<setters>
			<set name="keywords">teleport,bonus action</set>
			<set name="category">Wondrous Items</set>
			<set name="cost" currency="gp">400</set>
			<set name="type">Wondrous Item</set>
			<set name="slot">feet</set>
			<set name="rarity">Uncommon</set>
			<set name="attunement">true</set>
		</setters>
	</element>
	<element name="Helm of Awareness" type="Magic Item" source="Eberron: Forge of the Artificer" id="ID_WOTC_EFOTA_MAGIC_ITEM_HELM_OF_AWARENESS">
		<description>
			<p>While wearing this helmet, you have Advantage on Initiative rolls.</p>
		</description>
		<setters>
			<set name="keywords">initiative</set>
			<set name="category">Wondrous Items</set>
			<set name="cost" currency="gp">400</set>
			<set name="type">Wondrous Item</set>
			<set name="slot">head</set>
			<set name="rarity">Uncommon</set>
		</setters>
		<rules>
			<grant type="Grants" id="ID_INTERNAL_GRANTS_INITIATIVE_ADVANTAGE" />
		</rules>
	</element>
	<element name="Manifold Tool" type="Magic Item" source="Eberron: Forge of the Artificer" id="ID_WOTC_EFOTA_MAGIC_ITEM_MANIFOLD_TOOL">
		<description>
			<p>This tool takes the form of a wrench, a screwdriver, or another basic tool. As a Magic action, you can touch the item and transform it into a type of Artisan's Tools of your choice. Whatever form the tool takes, you have proficiency with it when you use it.</p>
		</description>
		<setters>
			<set name="keywords">tool,proficiency</set>
			<set name="category">Wondrous Items</set>
			<set name="cost" currency="gp">100</set>
			<set name="type">Wondrous Item</set>
			<set name="rarity">Common</set>
			<set name="attunement">true</set>
		</setters>
	</element>
</elements>
