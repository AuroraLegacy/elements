	<element name="Bandore" type="Item" source="Forgotten Realms: Heroes of Faerûn" id="ID_WOTC_FRHOF_INSTRUMENT_BANDORE">
		<supports>ID_INTERNAL_TOOL_MUSICAL_INSTRUMENT</supports>
		<description>
			<p class="flavor">The bandore is a complex bass instrument with additional sets of strings, perfect for accompanying tenor and alto instruments in an ensemble.</p>
			<h5>BANDORE</h5>
			<table>
				<tr><td><b>Ability:</b> Charisma</td><td><b>Weight:</b> 3 lb.</td></tr>
				<tr><td><b>Utilize:</b> Play a known tune (DC 10), or improvise a song (DC 15)</td></tr>
			</table>
		</description>
		<setters>
			<set name="category">Musical Instruments</set>
			<set name="cost" currency="gp">65</set>
			<set name="weight" lb="3">3 lbs.</set>
			<set name="slot">onehand</set>
			<set name="type">Tool</set>
			<set name="proficiency">ID_WOTC_PHB24_PROFICIENCY_TOOL_PROFICIENCY_BANDORE</set>
		</setters>
	</element>
	<element name="Cittern" type="Item" source="Forgotten Realms: Heroes of Faerûn" id="ID_WOTC_FRHOF_INSTRUMENT_CITTERN">
		<supports>ID_INTERNAL_TOOL_MUSICAL_INSTRUMENT</supports>
		<description>
			<p class="flavor">A cittern, distinguished by its pear-shaped bowl, produces a pleasing, richer sound.</p>
			<h5>CITTERN</h5>
			<table>
				<tr><td><b>Ability:</b> Charisma</td><td><b>Weight:</b> 2 lb.</td></tr>
				<tr><td><b>Utilize:</b> Play a known tune (DC 10), or improvise a song (DC 15)</td></tr>
