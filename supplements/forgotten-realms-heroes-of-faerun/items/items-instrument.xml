			<set name="weight" lb="2">2 lbs.</set>
			<set name="slot">onehand</set>
			<set name="type">Tool</set>
			<set name="proficiency">ID_WOTC_PHB24_PROFICIENCY_TOOL_PROFICIENCY_CITTERN</set>
