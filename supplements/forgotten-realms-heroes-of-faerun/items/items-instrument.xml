		<supports>ID_INTERNAL_TOOL_MUSICAL_INSTRUMENT</supports>
		<description>
			<p class="flavor">The yarting is the staple stringed instrument of minstrels across Faerûn.</p>
			<h5>YARTING</h5>
			<table>
				<tr><td><b>Ability:</b> Charisma</td><td><b>Weight:</b> 2 lb.</td></tr>
