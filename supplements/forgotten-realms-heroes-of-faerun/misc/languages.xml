<?xml version="1.0" encoding="utf-8" ?>
<elements>
	<info>
		<name>Languages</name>
		<description>Languages from Forgotten Realms: Heroes of Faerûn.</description>
		<author url="https://dndstore.wizards.com/us/en/product/1246485/heroes-of-faerun">Wizards of the Coast</author>
		<update version="0.0.1">
			<file name="languages.xml" url="https://raw.githubusercontent.com/AuroraLegacy/elements/master/supplements/forgotten-realms-heroes-of-faerun/misc/languages.xml" />
		</update>
	</info>

	<!-- Standard Languages -->
	<element name="Aglarondan" type="Language" source="Forgotten Realms: Heroes of Faerûn" id="ID_WOTC_FRHOF_LANGUAGE_AGLARONDAN">
		<supports>Standard, Faerûn</supports>
		<description>
			<p>Spoken by the inhabitants of Aglarond and the Yuirwood, one of the Arcane Empires of the East </p>
		</description>
	</element>

	<element name="Alzhedo" type="Language" source="Forgotten Realms: Heroes of Faerûn" id="ID_WOTC_FRHOF_LANGUAGE_ALZHEDO">
		<supports>Standard, Faerûn</supports>
		<description>
			<p>Spoken by the inhabitants of Calimshan to the south</p>
		</description>
	</element>

	<element name="Bothii" type="Language" source="Forgotten Realms: Heroes of Faerûn" id="ID_WOTC_FRHOF_LANGUAGE_BOTHII">
		<supports>Standard, Faerûn</supports>
		<description>
			<p>Spoken by the Uthgardt nomads who wander the tundras of the Savage Frontier and the Far North</p>
		</description>
	</element>

	<element name="Chessentan" type="Language" source="Forgotten Realms: Heroes of Faerûn" id="ID_WOTC_FRHOF_LANGUAGE_CHESSENTAN">
		<supports>Standard, Faerûn</supports>
		<description>
			<p>Spoken by the inhabitants of Chessenta, one of the Old Empires to the east.</p>
		</description>
	</element>

	<element name="Chondathan" type="Language" source="Forgotten Realms: Heroes of Faerûn" id="ID_WOTC_FRHOF_LANGUAGE_CHONDATHAN">
		<supports>Standard, Faerûn</supports>
		<description>
			<p>Spoken by the inhabitants of Chondath in the Vilhon Reach. Due to their vast trading influence, it is also spoken widely across the entirety of Faerûn</p>
		</description>
	</element>

	<element name="Damaran" type="Language" source="Forgotten Realms: Heroes of Faerûn" id="ID_WOTC_FRHOF_LANGUAGE_CHESSENTAN">
		<supports>Standard, Faerûn</supports>
		<description>
			<p>Spoken by the inhabitants of Damara in the Forgotten Lands to the northeast, as well as in the Heartlands.</p>
		</description>
	</element>

	<element name="Illuskan" type="Language" source="Forgotten Realms: Heroes of Faerûn" id="ID_WOTC_FRHOF_LANGUAGE_ILLUSKAN">
		<supports>Standard, Faerûn</supports>
		<description>
			<p>Spoken by the inhabitants of the Frozen North and the Trackless Sea</p>
		</description>
	</element>

	<element name="Lantanese" type="Language" source="Forgotten Realms: Heroes of Faerûn" id="ID_WOTC_FRHOF_LANGUAGE_LANTANESE">
		<supports>Standard, Faerûn</supports>
		<description>
			<p>Spoken by the inhabitants of Lantan, a distant archipelago in the southern expanse of the Trackless Sea</p>
		</description>
	</element>

	<element name="Midani" type="Language" source="Forgotten Realms: Heroes of Faerûn" id="ID_WOTC_FRHOF_LANGUAGE_MIDANI">
		<supports>Standard, Faerûn</supports>
		<description>
			<p>Spoken by the Bedine nomads who wander the wastelands of the Anauroch desert</p>
		</description>
	</element>

	<element name="Mulhorandi" type="Language" source="Forgotten Realms: Heroes of Faerûn" id="ID_WOTC_FRHOF_LANGUAGE_MULHORANDI">
		<supports>Standard, Faerûn</supports>
		<description>
			<p>Spoken by the inhabitants of Mulhorand, one of the Old Empires to the east.</p>
		</description>
	</element>

	<element name="Netherese" type="Language" source="Forgotten Realms: Heroes of Faerûn" id="ID_WOTC_FRHOF_LANGUAGE_NETHERESE">
		<supports>Standard, Faerûn</supports>
		<description>
			<p>The ancient language of the Netheril empire. It is spoken by the Shadovar living among the ruins of Thultantar and other Netherese ruins</p>
		</description>
	</element>

	<element name="Rashemi" type="Language" source="Forgotten Realms: Heroes of Faerûn" id="ID_WOTC_FRHOF_LANGUAGE_RASHEMI">
		<supports>Standard, Faerûn</supports>
		<description>
			<p>Spoken by the inhabitants of Rashemen, a land of wild tribes of berserkers and witches north of Thay.</p>
		</description>
	</element>

	<element name="Reghedjic" type="Language" source="Forgotten Realms: Heroes of Faerûn" id="ID_WOTC_FRHOF_LANGUAGE_REGHEDJIC">
		<supports>Standard, Faerûn</supports>
		<description>
			<p>Spoken by the Reghed nomads who wander the frozen lands of Icewind Dale and the Far North</p>
		</description>
	</element>

	<element name="Sespech" type="Language" source="Forgotten Realms: Heroes of Faerûn" id="ID_WOTC_FRHOF_LANGUAGE_SESPECH">
		<supports>Standard, Faerûn</supports>
		<description>
			<p>Spoken by the inhabitants of Sespech in the Vilhon Reach.</p>
		</description>
	</element>

	<element name="Thayan" type="Language" source="Forgotten Realms: Heroes of Faerûn" id="ID_WOTC_FRHOF_LANGUAGE_THAYAN">
		<supports>Standard, Faerûn</supports>
		<description>
			<p>Spoken by the inhabitants of Thay.</p>
		</description>
	</element>

	<element name="Turmic" type="Language" source="Forgotten Realms: Heroes of Faerûn" id="ID_WOTC_FRHOF_LANGUAGE_TURMIC">
		<supports>Standard, Faerûn</supports>
		<description>
			<p>Spoken by the inhabitants of Turmish in the Vilhon Reach.</p>
		</description>
	</element>

	<element name="Untheric" type="Language" source="Forgotten Realms: Heroes of Faerûn" id="ID_WOTC_FRHOF_LANGUAGE_UNTHERIC">
		<supports>Standard, Faerûn</supports>
		<description>
			<p>Spoken by the inhabitants of Unther, one of the Old Empires to the east.</p>
		</description>
	</element>
	
</elements>
